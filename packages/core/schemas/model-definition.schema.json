{
  "$id": "https://cdn.jsdelivr.net/npm/@contedra/core@0.0.0-PLACEHOLDER/schemas/model-definition.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ModelDefinition",
  "description": "A single Conteditor model definition (the Easy format).",
  "type": "object",
  "required": ["id", "modelName", "properties"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "modelName": {
      "type": "string",
      "minLength": 1
    },
    "properties": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ModelProperty"
      }
    }
  },
  "$defs": {
    "ModelProperty": {
      "type": "object",
      "required": ["propertyName", "dataType"],
      "additionalProperties": true,
      "properties": {
        "propertyName": {
          "type": "string",
          "minLength": 1
        },
        "dataType": {
          "type": "string",
          "enum": ["string", "datetime", "relatedOne", "relatedMany"]
        },
        "fieldType": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "element": {
              "type": "string"
            }
          }
        },
        "require": {
          "type": "boolean"
        },
        "defaultValue": {},
        "relatedModel": {
          "type": "string"
        }
      }
    }
  }
}
