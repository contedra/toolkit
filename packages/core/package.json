{
  "name": "@contedra/core",
  "version": "0.2.2",
  "description": "Core library for Contedra toolkit — Firebase connection, model parsing, and schema generation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas/model-definition.schema.json": "./schemas/model-definition.schema.json",
    "./schemas/model-manifest.schema.json": "./schemas/model-manifest.schema.json",
    "./schemas/*": "./schemas/*"
  },
  "files": [
    "dist",
    "schemas"
  ],
  "scripts": {
    "build": "tsc",
    "test": "firebase emulators:exec --only storage --project test \"vitest run\"",
    "lint": "oxlint src",
    "prepack": "node ../../scripts/rewrite-schema-ids.mjs"
  },
  "keywords": [
    "conteditor",
    "firestore",
    "firebase"
  ],
  "author": "Contedra",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/contedra/toolkit",
    "directory": "packages/core"
  },
  "dependencies": {
    "firebase-admin": "^13.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "oxlint": "^1.57.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
